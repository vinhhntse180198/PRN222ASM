@page
@model CKFS_Management.RazorwebApp.VinhHNT.Pages.RecipesVinhHnts.EditModel
@{
    ViewData["Title"] = "Sửa công thức";
}

<div class="container py-4" id="editPageContainer">
    <div id="toastEdit" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>
    <div class="card card-form-ckfs">
        <div class="card-header text-dark" style="background: #fef3c7;">
            <i class="fas fa-edit me-2"></i>Sửa công thức #@Model.RecipeVinhHnt.RecipeId
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="RecipeVinhHnt.RecipeId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RecipeVinhHnt.ProductId" class="form-label fw-semibold">Sản phẩm</label>
                        <select asp-for="RecipeVinhHnt.ProductId" class="form-select" asp-items="Model.ProductIdList">
                            <option value="">-- Chọn sản phẩm --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="RecipeVinhHnt.IngredientId" class="form-label fw-semibold">Nguyên liệu</label>
                        <select asp-for="RecipeVinhHnt.IngredientId" class="form-select" asp-items="Model.IngredientIdList">
                            <option value="">-- Chọn nguyên liệu --</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="RecipeVinhHnt.Quantity" class="form-label fw-semibold">Số lượng</label>
                        <input asp-for="RecipeVinhHnt.Quantity" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="RecipeVinhHnt.Quantity" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="RecipeVinhHnt.Unit" class="form-label fw-semibold">Đơn vị</label>
                        <input asp-for="RecipeVinhHnt.Unit" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="RecipeVinhHnt.Version" class="form-label fw-semibold">Phiên bản</label>
                        <input asp-for="RecipeVinhHnt.Version" class="form-control" type="number" />
                    </div>
                </div>
                <div class="d-flex gap-2 pt-2">
                    <a asp-page="Index" class="btn btn-ckfs-outline">Hủy</a>
                    <button type="submit" class="btn btn-ckfs-primary">Lưu (HTTP)</button>
                    <button type="button" id="btnHubUpdate" class="btn btn-warning">Cập nhật qua SignalR</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/recipesHub").build();
        const recipeId = @Model.RecipeVinhHnt.RecipeId;

        function showToastEdit(msg, type) {
            type = type || 'info';
            const toast = document.getElementById('toastEdit');
            toast.innerHTML = '<div class="alert alert-' + type + ' shadow-sm alert-dismissible fade show">' + msg + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            setTimeout(function() { toast.innerHTML = ''; }, 4000);
        }

        function applyUpdateToForm(payload) {
            const r = payload || {};
            const pid = r.productId != null ? r.productId : r.ProductId;
            const iid = r.ingredientId != null ? r.ingredientId : r.IngredientId;
            const q = document.querySelector("[name='RecipeVinhHnt.Quantity']");
            const u = document.querySelector("[name='RecipeVinhHnt.Unit']");
            const v = document.querySelector("[name='RecipeVinhHnt.Version']");
            const sp = document.querySelector("[name='RecipeVinhHnt.ProductId']");
            const si = document.querySelector("[name='RecipeVinhHnt.IngredientId']");
            if (q && r.quantity != null) q.value = r.quantity;
            if (u) u.value = r.unit || '';
            if (v && r.version != null) v.value = r.version;
            if (sp && pid != null) sp.value = pid;
            if (si && iid != null) si.value = iid;
        }

        connection.on("UpdateSuccess", function(payload) {
            showToastEdit('<i class="fas fa-check-circle me-2"></i>Cập nhật thành công! Đang chuyển...', 'success');
            setTimeout(function() { window.location.href = "/RecipesVinhHnts"; }, 800);
        });
        connection.on("ReceiveUpdate_Recipe", function(payload) {
            const id = payload && (payload.recipeId || payload.RecipeId);
            if (parseInt(id) !== recipeId) return;
            applyUpdateToForm(payload);
            showToastEdit('<i class="fas fa-sync-alt me-2"></i>Đã cập nhật từ nơi khác. Form đã được đồng bộ.', 'info');
        });
        connection.on("ReceiveDelete_Recipe", function(deletedId) {
            if (parseInt(deletedId) !== recipeId) return;
            document.getElementById('editPageContainer').innerHTML = '<div class="alert alert-danger shadow"><i class="fas fa-exclamation-triangle me-2"></i>Công thức này vừa bị xóa. <a href="/RecipesVinhHnts">Quay lại danh sách</a></div>';
        });
        connection.on("ReceiveErrorRecipe", (msg) => alert("Lỗi: " + msg));
        connection.start().catch(err => console.error(err));

        document.getElementById("btnHubUpdate").addEventListener("click", function(e) {
            e.preventDefault();
            const data = {
                RecipeId: recipeId,
                ProductId: parseInt(document.querySelector("[name='RecipeVinhHnt.ProductId']").value) || null,
                IngredientId: parseInt(document.querySelector("[name='RecipeVinhHnt.IngredientId']").value) || null,
                Quantity: parseFloat(document.querySelector("[name='RecipeVinhHnt.Quantity']").value) || 0,
                Unit: document.querySelector("[name='RecipeVinhHnt.Unit']").value || null,
                Version: parseInt(document.querySelector("[name='RecipeVinhHnt.Version']").value) || null
            };
            connection.invoke("HubUpdate_Recipe", data).catch(err => console.error(err));
        });
    </script>
}
