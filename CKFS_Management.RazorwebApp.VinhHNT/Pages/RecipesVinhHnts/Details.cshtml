@page
@model CKFS_Management.RazorwebApp.VinhHNT.Pages.RecipesVinhHnts.DetailsModel
@{
    ViewData["Title"] = "Chi tiết công thức";
}

<div class="container py-4" id="detailsPageContainer">
    <div id="toastDetails" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>
    <div class="card card-form-ckfs">
        <div class="card-header text-white" style="background: #0ea5e9;">
            <i class="fas fa-info-circle me-2"></i>Chi tiết công thức #@Model.RecipeVinhHnt.RecipeId
        </div>
        <div class="card-body p-4" id="detailsCardBody">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted fw-semibold">Sản phẩm</dt>
                <dd class="col-sm-9" id="ddProduct">@(Model.RecipeVinhHnt.Product?.Name ?? "-")</dd>
                <dt class="col-sm-3 text-muted fw-semibold">Nguyên liệu</dt>
                <dd class="col-sm-9" id="ddIngredient">@(Model.RecipeVinhHnt.Ingredient?.Name ?? "-")</dd>
                <dt class="col-sm-3 text-muted fw-semibold">Số lượng</dt>
                <dd class="col-sm-9" id="ddQuantity">@Model.RecipeVinhHnt.Quantity</dd>
                <dt class="col-sm-3 text-muted fw-semibold">Đơn vị</dt>
                <dd class="col-sm-9" id="ddUnit">@Model.RecipeVinhHnt.Unit</dd>
                <dt class="col-sm-3 text-muted fw-semibold">Phiên bản</dt>
                <dd class="col-sm-9" id="ddVersion">@Model.RecipeVinhHnt.Version</dd>
                <dt class="col-sm-3 text-muted fw-semibold">Ngày tạo</dt>
                <dd class="col-sm-9" id="ddCreatedAt">@Model.RecipeVinhHnt.CreatedAt</dd>
            </dl>
            <div class="d-flex gap-2 mt-4 pt-3 border-top">
                <a asp-page="Index" class="btn btn-ckfs-outline">Quay lại</a>
                <a asp-page="Edit" asp-route-id="@Model.RecipeVinhHnt.RecipeId" class="btn btn-ckfs-primary">Sửa</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/recipesHub").build();
        const recipeId = @Model.RecipeVinhHnt.RecipeId;
        connection.on("ReceiveUpdate_Recipe", function(payload) {
            if (!payload || Number(payload.recipeId || payload.RecipeId) !== recipeId) return;
            const r = payload;
            const el = function(id) { return document.getElementById(id); };
            if (el('ddProduct')) el('ddProduct').textContent = r.productName || r.ProductName || '-';
            if (el('ddIngredient')) el('ddIngredient').textContent = r.ingredientName || r.IngredientName || '-';
            if (el('ddQuantity')) el('ddQuantity').textContent = r.quantity != null ? r.quantity : '-';
            if (el('ddUnit')) el('ddUnit').textContent = r.unit || r.Unit || '-';
            if (el('ddVersion')) el('ddVersion').textContent = r.version != null ? r.version : '-';
            const toast = document.getElementById('toastDetails');
            if (toast) toast.innerHTML = '<div class="alert alert-info shadow-sm alert-dismissible fade show"><i class="fas fa-sync-alt me-2"></i>Đã cập nhật từ nơi khác.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            setTimeout(function() { if (toast) toast.innerHTML = ''; }, 3000);
        });
        connection.on("ReceiveDelete_Recipe", function(deletedId) {
            if (parseInt(deletedId) !== recipeId) return;
            document.getElementById('detailsCardBody').innerHTML = '<div class="alert alert-danger"><i class="fas fa-exclamation-triangle me-2"></i>Công thức này đã bị xóa.<br/><a href="/RecipesVinhHnts" class="btn btn-outline-danger mt-2">Quay lại danh sách</a></div>';
        });
        connection.start().catch(err => console.error(err));
    </script>
}
