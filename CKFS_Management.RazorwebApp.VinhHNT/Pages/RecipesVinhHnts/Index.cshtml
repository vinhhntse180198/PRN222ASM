@page
@model CKFS_Management.RazorwebApp.VinhHNT.Pages.RecipesVinhHnts.IndexModel
@{
    ViewData["Title"] = "Quản lý Công thức";
}

<div class="container-fluid py-4">
    <div class="page-header-ckfs d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="h5 mb-1 fw-bold"><i class="fas fa-list-alt me-2 text-primary"></i>Quản lý Công thức (Recipes)</h1>
            <small class="text-muted">Xem và quản lý công thức sản phẩm</small>
        </div>
        <a asp-page="Create" class="btn btn-ckfs-primary"><i class="fas fa-plus me-2"></i>Tạo mới</a>
    </div>

    <div class="card card-form-ckfs">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-ckfs table-hover align-middle mb-0" id="recipeTable">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3">ID</th>
                            <th class="py-3">Sản phẩm</th>
                            <th class="py-3">Nguyên liệu</th>
                            <th class="py-3">Số lượng</th>
                            <th class="py-3">Đơn vị</th>
                            <th class="py-3">Phiên bản</th>
                            <th class="py-3 text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="recipeTableBody">
                        @foreach (var item in Model.Recipes)
                        {
                            <tr id="recipe-@item.RecipeId">
                                <td class="ps-4 fw-bold">@item.RecipeId</td>
                                <td>@(item.Product?.Name ?? "-")</td>
                                <td>@(item.Ingredient?.Name ?? "-")</td>
                                <td>@item.Quantity</td>
                                <td>@item.Unit</td>
                                <td>@item.Version</td>
                                <td class="text-end pe-4">
                                    <a asp-page="./Edit" asp-route-id="@item.RecipeId" class="btn btn-sm btn-light border text-primary" title="Sửa"><i class="fas fa-pen"></i></a>
                                    <a asp-page="./Details" asp-route-id="@item.RecipeId" class="btn btn-sm btn-light border text-info" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                    <a asp-page="./Delete" asp-route-id="@item.RecipeId" class="btn btn-sm btn-light border text-danger" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="toastRealtime" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/recipesHub").build();

        function addRecipeRow(payload) {
            const r = payload || {};
            const id = r.recipeId || r.RecipeId;
            if (!id) return;
            if (document.querySelector(`tr#recipe-${id}`)) return;
            const productName = r.productName || r.ProductName || '-';
            const ingredientName = r.ingredientName || r.IngredientName || '-';
            const quantity = r.quantity != null ? r.quantity : '-';
            const unit = r.unit || r.Unit || '-';
            const version = r.version != null ? r.version : '-';
            const tr = document.createElement('tr');
            tr.id = `recipe-${id}`;
            tr.innerHTML = `
                <td class="ps-4 fw-bold">${id}</td>
                <td>${productName}</td>
                <td>${ingredientName}</td>
                <td>${quantity}</td>
                <td>${unit}</td>
                <td>${version}</td>
                <td class="text-end pe-4">
                    <a href="/RecipesVinhHnts/Edit?id=${id}" class="btn btn-sm btn-light border text-primary" title="Sửa"><i class="fas fa-pen"></i></a>
                    <a href="/RecipesVinhHnts/Details?id=${id}" class="btn btn-sm btn-light border text-info" title="Chi tiết"><i class="fas fa-eye"></i></a>
                    <a href="/RecipesVinhHnts/Delete?id=${id}" class="btn btn-sm btn-light border text-danger" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                </td>
            `;
            document.getElementById('recipeTableBody').appendChild(tr);
        }

        connection.on("ReceiveDelete_Recipe", function(recipeId) {
            document.querySelector(`tr#recipe-${recipeId}`)?.remove();
        });
        connection.on("ReceiveCreate_Recipe", function(payload) {
            addRecipeRow(payload);
            const toast = document.getElementById('toastRealtime');
            toast.innerHTML = '<div class="alert alert-success shadow-sm alert-dismissible fade show" role="alert"><i class="fas fa-check-circle me-2"></i>Có công thức mới được tạo.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            setTimeout(() => { toast.innerHTML = ''; }, 3000);
        });
        connection.on("ReceiveUpdate_Recipe", function(payload) {
            const id = payload?.recipeId || payload?.RecipeId;
            if (id) {
                const row = document.querySelector(`tr#recipe-${id}`);
                if (row) {
                    const productName = payload.productName || payload.ProductName || '-';
                    const ingredientName = payload.ingredientName || payload.IngredientName || '-';
                    row.cells[1].textContent = productName;
                    row.cells[2].textContent = ingredientName;
                    row.cells[3].textContent = payload.quantity != null ? payload.quantity : '-';
                    row.cells[4].textContent = payload.unit || payload.Unit || '-';
                    row.cells[5].textContent = payload.version != null ? payload.version : '-';
                }
            }
        });
        connection.start().catch(err => console.error(err));
    </script>
}
