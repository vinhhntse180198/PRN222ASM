@page
@model CKFS_Management.RazorwebApp.VinhHNT.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Đăng xuất";
}

<div class="container py-5">
    <div class="card card-form-ckfs mx-auto text-center" style="max-width: 420px;">
        <div class="card-body p-5">
            <i class="fas fa-sign-out-alt fa-3x text-muted mb-3"></i>
            <h2 class="h5 fw-bold mb-2">Bạn đã đăng xuất</h2>
            <p class="text-muted small mb-4">Cảm ơn bạn đã sử dụng CKFS Management.</p>
            <a asp-page="/Account/Login" class="btn btn-ckfs-primary me-2">Đăng nhập lại</a>
            <a asp-page="/Index" class="btn btn-ckfs-outline">Về trang chủ</a>
        </div>
    </div>
</div>
