@page
@model CKFS_Management.RazorwebApp.VinhHNT.Pages.Account.ForbiddenModel
@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container py-5">
    <div class="card card-form-ckfs mx-auto" style="max-width: 480px;">
        <div class="card-body p-5 text-center">
            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="fas fa-ban fa-2x text-warning"></i>
            </div>
            <h2 class="h5 fw-bold mb-2">Bạn không có quyền truy cập trang này</h2>
            <p class="text-muted small mb-4">Vui lòng đăng nhập với tài khoản có quyền phù hợp hoặc quay lại trang chủ.</p>
            <a asp-page="/Index" class="btn btn-ckfs-primary">Về trang chủ</a>
        </div>
    </div>
</div>
